# =============================================================================
# Ansible Vault 示例：Dev 应用敏感变量（明文结构参考 — 勿直接提交）
# =============================================================================
#
# 【如何使用】
#   1. cp secrets.yml.example secrets.yml
#   2. ansible-vault encrypt ansible/inventories/dev/group_vars/all/secrets.yml
#   3. playbook 使用 --vault-password-file .vault_pass
#
# 【消费者】
#   dev-app.yml / app_deploy role 渲染 /opt/app/compose/.env
#   gateway-compose.yml / gateway_compose role 渲染 /opt/gateway/compose/.env
#
# 【无 vault 时】
#   可不创建本文件；app_deploy 使用 (app_secrets | default({})).db_password 空字符串
#   gateway-compose 必须提供 gateway_secrets.aliyun_dns_*（可用 --extra-vars 临时传入）
#
# =============================================================================

app_secrets:
  db_password: "REPLACE_WITH_app_dev_PASSWORD"
  # redis_password: "REPLACE_WHEN_dev-02_READY"
  # oss_access_key_id: null
  # oss_access_key_secret: null

gateway_secrets:
  aliyun_dns_access_key: "REPLACE_WITH_RAM_ACCESS_KEY"
  aliyun_dns_access_key_secret: "REPLACE_WITH_RAM_ACCESS_KEY_SECRET"
