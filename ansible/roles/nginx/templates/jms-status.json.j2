{
  "service": "jumpserver",
  "deploy_status": "{{ nginx_jumpserver_deploy_status }}",
  "upstream": "{{ nginx_jumpserver_upstream }}",
{% if nginx_jumpserver_deploy_status == 'ready' %}
  "message": "JumpServer operational; proxy via Hub Nginx to {{ nginx_jumpserver_upstream }}"
{% else %}
  "message": "JumpServer not deployed; upstream pending. See docs/jumpserver/hub-jumpserver.runbook.md"
{% endif %}
}
