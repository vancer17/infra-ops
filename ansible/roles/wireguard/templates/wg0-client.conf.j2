# =============================================================================
# WireGuard ECS Peer 配置 — 由 Ansible 管理，勿手工编辑
# =============================================================================
# Peer：{{ wireguard_peer_name | default('unknown') }}
# 生成：wireguard role / wg0-client.conf.j2
# Hub Endpoint：{{ wireguard_client_hub_endpoint }}
# =============================================================================

[Interface]
PrivateKey = {{ wireguard_peer_private_key }}
Address = {{ wireguard_peer_address }}
{% if wireguard_client_dns | default('') | length > 0 %}
# 阶段 G2：Hub dnsmasq @ {{ wireguard_client_dns }} 解析 *.internal（须 internal_dns operational）
DNS = {{ wireguard_client_dns }}
{% endif %}

[Peer]
# hub-01 WireGuard Server
PublicKey = {{ wireguard_client_hub_public_key }}
Endpoint = {{ wireguard_client_hub_endpoint }}
AllowedIPs = {{ wireguard_client_allowed_ips }}
PersistentKeepalive = {{ wireguard_client_persistent_keepalive }}
