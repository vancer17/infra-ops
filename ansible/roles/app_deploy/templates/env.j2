# Managed by Ansible infra-ops (app_deploy role)
# Environment: {{ env_name | default('dev') }} / {{ app_env_vars.APP_ENV | default('dev') }}

ENV={{ app_env_vars.ENV | default('development') }}
APP_ENV={{ app_env_vars.APP_ENV | default('development') }}
LOG_LEVEL={{ app_env_vars.LOG_LEVEL | default('DEBUG') }}
SWAGGER_ENABLED={{ app_env_vars.SWAGGER_ENABLED | default('true') }}

{% if app_use_rds_from_inventory | bool %}
DB_HOST={{ rds.host | default('') }}
DB_PORT={{ rds.port | default(3306) }}
DB_NAME={{ rds.database | default('app_dev') }}
DB_USER={{ rds.user | default('app_dev') }}
DB_PASSWORD={{ app_secrets_db_password }}
{% endif %}

{% if app_use_oss_from_inventory | bool %}
OSS_BUCKET={{ oss.bucket | default('') }}
OSS_PREFIX={% if oss.prefix | default('', true) %}{{ oss.prefix }}/{% endif %}
{% endif %}

DEPLOY_STATUS={{ app_deploy_status }}
