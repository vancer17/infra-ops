# =============================================================================
# Dev Gateway Compose — 渲染 docker/dev-gateway/.env
# Managed by Ansible infra-ops (gateway_compose role)
# =============================================================================

# --- 预构建镜像（本地 infra-ops/*；registry 模式时为 ACR 完整路径）---
GATEWAY_IMAGE_CERTBOT_INIT={{ gateway_image_certbot_init_ref }}
GATEWAY_IMAGE_CERTBOT_RENEW={{ gateway_image_certbot_renew_ref }}
GATEWAY_IMAGE_NGINX={{ gateway_image_nginx_ref }}

# --- Let's Encrypt ---
CERTBOT_EMAIL={{ gateway_certbot_email }}
CERTBOT_DOMAINS={{ gateway_certbot_domains }}
CERTBOT_PRIMARY_DOMAIN={{ gateway_certbot_primary_domain }}

CERTBOT_STAGING={{ 1 if gateway_certbot_staging | bool else 0 }}
CERTBOT_FORCE_ISSUE={{ 1 if gateway_certbot_force_issue | bool else 0 }}
CERTBOT_DNS_PROPAGATION_SECONDS={{ gateway_certbot_propagation_seconds }}
CERTBOT_RSA_KEY_SIZE={{ gateway_certbot_rsa_key_size }}

# --- 阿里云 DNS API（DNS-01）---
ALIYUN_DNS_ACCESS_KEY={{ gateway_aliyun_dns_access_key }}
ALIYUN_DNS_ACCESS_KEY_SECRET={{ gateway_aliyun_dns_access_key_secret }}

# --- certbot-renew ---
RENEW_INTERVAL_SECONDS={{ gateway_renew_interval_seconds }}
WAIT_FOR_CERT_SEC={{ gateway_wait_for_cert_sec }}

# --- Nginx ---
NGINX_SERVER_NAMES="{{ gateway_nginx_server_names }}"
NGINX_INTERNAL_SERVER_NAMES="{{ gateway_nginx_internal_server_names }}"

APP_UPSTREAM_HOST={{ gateway_upstream_host }}
APP_UPSTREAM_PORT={{ gateway_upstream_port }}
