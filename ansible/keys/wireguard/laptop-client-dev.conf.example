# =============================================================================
# WireGuard Client — 开发人员模板（billmiao / sammao / zhu / xinxin）
# =============================================================================
# 使用前替换：
#   PEER_NAME     → inventory 中的 peer 名（如 laptop-billmiao）
#   WG_ADDRESS    → 10.200.10.x/32（见 docs/assets/wireguard-clients.yaml）
#   PRIVATE_KEY   → generate-peer 生成的 *.private 内容（勿提交 Git）
# 生成配置：./scripts/wireguard/render-laptop-conf.sh <peer_name>
# =============================================================================

[Interface]
PrivateKey = REPLACE_WITH_PRIVATE_KEY
Address = WG_ADDRESS/32
DNS = 10.200.0.1

[Peer]
PublicKey = MNczHi1IQ4l8zkEPIQL1sPxSEPputkPdo2neaZWkFj8=
Endpoint = 121.43.49.58:51820
AllowedIPs = 10.200.0.0/24, 10.200.1.0/24, 10.200.2.0/24
PersistentKeepalive = 25
