# =============================================================================
# infra-ops — 基础设施与运维仓库
# =============================================================================

# Ansible 1.3 CI 部署私钥（公钥 infra-ci-deploy.pub 可提交）
ansible/keys/infra-ci-deploy
!ansible/keys/infra-ci-deploy.pub
!ansible/keys/*.example
!ansible/keys/README.md

# WireGuard 私钥（公钥 *.pub 与 README 可提交）
ansible/keys/wireguard/*.private
ansible/keys/wireguard/hub.private
!ansible/keys/wireguard/*.pub.example
!ansible/keys/wireguard/*.private.example
!ansible/keys/wireguard/README.md

# -----------------------------------------------------------------------------
# 密钥、证书、敏感配置（切勿提交）
# -----------------------------------------------------------------------------
*.pem
*.key
*.p12
*.pfx
*.crt.local
*.csr
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
known_hosts.local
secrets/
secret/
*.secret
*.secrets
vault-password.txt
.vault_pass
.vault_pass.txt
*.gpg
!*.gpg.example

# WireGuard 实际配置（仅提交 .example 模板）
wg0.conf
wg*.conf
!*.conf.example
!*.example
peers.yml
peers.yaml
!peers.example.yml
!peers.example.yaml

# 环境变量与本地覆盖
.env
.env.*
!.env.example
!.env.*.example
*.local
*.local.yml
*.local.yaml
*.override.yml
*.override.yaml

# JumpServer / 平台组件本地配置
jumpserver/.env
jumpserver/data/
jumpserver/static/
monitoring/data/
monitoring/grafana/data/
monitoring/prometheus/data/

