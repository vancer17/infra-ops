*.retry
.ansible/
.ansible-staging/
ansible.log
ansible-navigator.log
collections/ansible_collections/

# Ansible Vault 加密前的明文备份
*.vault.plain
*.decrypted

# 动态 inventory 缓存
*.cache
inventory/*.local
inventory/local/

