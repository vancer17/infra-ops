# =============================================================================
# Dev Gateway Compose 环境变量示例
# 复制为 .env 后填写真值（.env 已被仓库根 .gitignore 忽略）
# =============================================================================

# --- 预构建镜像（本地 docker tag：infra-ops/*，勿使用轩辕加速站作为自建镜像仓库）---
GATEWAY_IMAGE_CERTBOT_INIT=infra-ops/certbot-init:1.0.2
GATEWAY_IMAGE_CERTBOT_RENEW=infra-ops/certbot-renew:1.0.2
GATEWAY_IMAGE_NGINX=infra-ops/dev-nginx:1.0.2

# --- Let's Encrypt ---
# 空格分隔多域；MQTT 子域须列入以便 SAN 覆盖 mqtt.yizuxing.com（与 API 同证时 primary 仍为 backend）
CERTBOT_EMAIL=you@example.com
CERTBOT_DOMAINS=backend.yizuxing.com mqtt.yizuxing.com
CERTBOT_PRIMARY_DOMAIN=backend.yizuxing.com

# 1 = 使用 LE Staging（仅验证 DNS-01 流程，证书不受微信信任）
CERTBOT_STAGING=0

# 1 = 即使已有有效证书也强制重新签发
CERTBOT_FORCE_ISSUE=0

# DNS TXT 传播等待秒数（阿里云 DNS 建议 60–120）
CERTBOT_DNS_PROPAGATION_SECONDS=90

# 证书 RSA 密钥长度
CERTBOT_RSA_KEY_SIZE=4096

# --- 阿里云 DNS API（DNS-01 必填）---
# RAM 用户需具备 AliyunDNSFullAccess，或最小化 _acme-challenge TXT 读写权限
ALIYUN_DNS_ACCESS_KEY=
ALIYUN_DNS_ACCESS_KEY_SECRET=

# --- certbot-renew ---
# 续期轮询间隔（秒）；默认 12 小时
RENEW_INTERVAL_SECONDS=43200
# 等待 init 写入证书的最长时间（秒）
WAIT_FOR_CERT_SEC=900

# --- Nginx（host 网络，反代宿主机应用）---
# 空格分隔；须包含小程序使用的备案域名；可保留公网 IP 过渡期
NGINX_SERVER_NAMES="backend.yizuxing.com 121.41.58.20"

# WG 内网 HTTP（可选；留空则仅公网 server_name 使用 80→301）
# 设置后 dev-app.internal / 10.200.0.2 可走 HTTP 反代，不强制 HTTPS
NGINX_INTERNAL_SERVER_NAMES="dev-app.internal 10.200.0.2"

# 宿主机上 PetIntelli / 占位 API 监听地址
APP_UPSTREAM_HOST=127.0.0.1
APP_UPSTREAM_PORT=8080

# --- MQTT（路线 A：公网 MQTTS 8883，不暴露明文 1883）---
# 1 = 启用 Nginx stream TLS 终止并反代至本机 Broker
NGINX_MQTT_TLS_ENABLED=1
# 设备连接主机名（须出现在 LE 证 SAN 中，见 CERTBOT_DOMAINS）
MQTT_TLS_DOMAIN=mqtt.yizuxing.com
MQTT_TLS_PORT=8883
# 与 API 同一张 LE 证时填 CERTBOT_PRIMARY_DOMAIN；独立签 mqtt 证时填 mqtt.yizuxing.com
MQTT_TLS_CERT_DOMAIN=backend.yizuxing.com
# Broker 仅监听回环/内网明文端口（勿对公网安全组开放 1883）
MQTT_UPSTREAM_HOST=127.0.0.1
MQTT_UPSTREAM_PORT=1883
