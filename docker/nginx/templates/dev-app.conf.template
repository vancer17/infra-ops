# =============================================================================
# Dev 业务 Nginx（Docker / host 网络）
# 公网 HTTPS：Let's Encrypt（DNS-01，卷挂载）
# 模板变量由官方 nginx 镜像 entrypoint 经 envsubst 渲染
# =============================================================================

upstream app_backend {
    server ${APP_UPSTREAM_HOST}:${APP_UPSTREAM_PORT};
    keepalive 16;
}

# 公网 HTTP → HTTPS（default_server）
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name ${NGINX_SERVER_NAMES};

    return 301 https://$host$request_uri;
}

# 公网 HTTPS（LE 证书）
server {
    listen 443 ssl default_server;
    listen [::]:443 ssl default_server;
    server_name ${NGINX_SERVER_NAMES};

    ssl_certificate /etc/letsencrypt/live/${CERTBOT_PRIMARY_DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${CERTBOT_PRIMARY_DOMAIN}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;

    access_log /var/log/nginx/dev-app.access.log;
    error_log /var/log/nginx/dev-app.error.log;

    client_max_body_size 32m;

    # Nginx 静态探针（不反代后端）
    location = /health {
        default_type text/plain;
        return 200 "ok\n";
    }

    # FastAPI：/healthz /readyz /docs /api/...
    location / {
        proxy_pass http://app_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_read_timeout 60s;
        proxy_connect_timeout 10s;
    }
}
