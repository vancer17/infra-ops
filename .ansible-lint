---
profile: production

exclude_paths:
  - .github/
  - .venv/
  - venv/
  - jumpserver/data/
  - monitoring/data/
  - ansible/requirements.yml

skip_list:
  - schema[version]
  - name[casing]
  - yaml[line-length]

warn_list:
  - no-changed-when
  - command-instead-of-shell

kinds:
  - playbook: "ansible/**/*.{yml,yaml}"
  - playbook: "ansible/*.{yml,yaml}"
  - vars: "inventory/group_vars/**/*.{yml,yaml}"
  - vars: "inventory/host_vars/**/*.{yml,yaml}"
  - meta: "ansible/roles/**/meta/main.{yml,yaml}"
  - tasks: "ansible/roles/**/tasks/*.{yml,yaml}"
  - handlers: "ansible/roles/**/handlers/*.{yml,yaml}"
